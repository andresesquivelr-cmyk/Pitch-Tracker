# Frontend environment variables — copy to frontend/.env and fill in your values
# These are safe to expose in the browser (Supabase RLS + anon key is designed for this)

# From: Supabase project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
